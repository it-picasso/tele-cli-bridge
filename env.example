# Example environment file for tele-cli-bridge.
# Copy to `.env` (gitignored) and edit. The bot reads it via `set -a; . ./.env; set +a`
# in run.sh, so every variable becomes an environment variable for the JVM.
#
# Values here override the defaults baked into src/main/resources/application.properties.
# Anything you leave commented out falls back to the property file default.

# --- Required (no defaults) ---

# Telegram bot @username (the `@` prefix is optional and stripped automatically).
BOT_NAME=your_bot_username

# Telegram bot token from @BotFather.
BOT_TOKEN=123456789:ABCdef...your-token-here

# --- Toolchain (optional) ---

# Path to your JDK 22 install. If your default `java` is already 22 you can leave this commented.
# When set, run.sh prepends $JAVA_HOME/bin to PATH for both the maven build and the JVM launch.
#JAVA_HOME=/path/to/jdk-22

# --- Telegram access (optional) ---

# Comma-separated Telegram user IDs that may DM the bot. Empty = all users allowed.
# Tip: send any message to @userinfobot to learn your user ID.
#BOT_USERS_ALLOWED=REDACTED

# Comma-separated Telegram user IDs that may use /model. Empty = no one is admin.
#BOT_USERS_ADMIN=REDACTED

# Comma-separated allowed group/supergroup chat IDs (negative numbers). Empty = all groups allowed.
# Tip: add the bot to a group, send any message, look for `ChatId=...` in bot.log.
#BOT_GROUPS_ALLOWED=REDACTED

# Comma-separated trigger phrases that activate the bot in groups (case-insensitive).
# Empty = require @<bot-username> mention to activate.
#BOT_TRIGGER_PHRASES=Claude,Gemini

# --- Models (optional) ---

# Default provider for new chats: claude or gemini.
#DEFAULT_PROVIDER=claude

# Comma-separated allowlist of Claude models shown in /model keyboard.
#CLAUDE_MODELS=claude-sonnet-4-6,claude-haiku-4-5

# Comma-separated allowlist of Gemini models shown in /model keyboard.
#GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

# Initial model used for new Claude-backed chats.
#CLAUDE_DEFAULT_MODEL=claude-haiku-4-5

# Initial model used for new Gemini-backed chats.
#GEMINI_DEFAULT_MODEL=gemini-2.5-flash-lite

# Claude reasoning effort. Values: low | medium | high | xhigh | max  (empty = CLI default).
#CLAUDE_EFFORT=low

# --- Tools (optional, OFF by default) ---

# Allowed Claude built-in tools (comma-separated). Empty = no tools (default — strict lockdown).
# Examples: WebSearch | WebSearch,WebFetch
# Enabling tools widens the threat surface (search-result prompt injection, query disclosure,
# SSRF risk for WebFetch). Read README "Security model" before enabling.
#CLAUDE_TOOLS=WebSearch

# Allowed Gemini built-in tools (comma-separated). Empty = no tools (default).
# Examples: google_web_search | google_web_search,web_fetch
#GEMINI_TOOLS=google_web_search

# --- CLI invocation (optional) ---

# Path to the claude binary (default: claude on PATH).
#CLAUDE_BINARY=claude

# Path to the gemini binary (default: gemini on PATH).
#GEMINI_BINARY=gemini

# Source directory for claude-cli/CLAUDE.md (security file is copied from here into a tmp sandbox at startup).
#CLAUDE_WORKDIR=./claude-cli

# Source directory for gemini-cli/GEMINI.md (security file is copied from here into a tmp sandbox at startup).
#GEMINI_WORKDIR=./gemini-cli

# Per-call subprocess timeout in seconds. Times out -> destroyForcibly().
#CLI_TIMEOUT_SECONDS=120

# Minutes of inactivity after which a chat's history auto-resets.
#CONVERSATION_EXPIRATION=60

# --- Misc (optional) ---

# Spring Boot HTTP port (Tomcat is brought up by spring-boot-starter-web; bot itself is long-polling).
#SERVER_PORT=8191

# Log level for the pro.xpst package. DEBUG | INFO | WARN | ERROR.
#LOG_LEVEL=DEBUG
